{
  "name": "lanjing",
  "version": "0.1.0",
  "private": true,
  "description": "LanJing — cross-platform media discovery and reading workbench",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:web": "vitest run",
    "lint:web": "eslint .",
    "lint:fix:web": "eslint . --fix",
    "typecheck:web": "svelte-check --tsconfig ./tsconfig.json",
    "format:web": "prettier --write \"src/**/*.{svelte,ts,js,css,html,json}\" \"*.{json,js,mjs,ts,html}\"",
    "format:check:web": "prettier --check \"src/**/*.{svelte,ts,js,css,html,json}\" \"*.{json,js,mjs,ts,html}\"",
    "lint": "pnpm run lint:web",
    "format": "pnpm run format:web",
    "format:check": "pnpm run format:check:web",
    "check": "pnpm run lint:web && pnpm run typecheck:web && pnpm run format:check:web"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.20.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.2.1",
    "@tauri-apps/plugin-store": "^2.2.1",
    "bits-ui": "^2.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "svelte": "^5.56.3",
    "svelte-sonner": "^1.1.1",
    "svelte-toolbelt": "^0.10.6",
    "tabbable": "^6.4.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.23.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "shadcn-svelte": "^1.3.0",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.11.0"
}
