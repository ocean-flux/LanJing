{
  "$schema": "https://inlang.com/schema/project-settings",
  "baseLocale": "zh-CN",
  "locales": ["en", "zh-CN"],
  "modules": ["https://cdn.jsdelivr.net/npm/@inlang/plugin-message-format@4.4.0/dist/index.js"],
  "plugin.inlang.messageFormat": {
    "pathPattern": [
      "./messages/{locale}/common.json",
      "./messages/{locale}/shell.json",
      "./messages/{locale}/realm.json",
      "./messages/{locale}/sources.json",
      "./messages/{locale}/apps.json",
      "./messages/{locale}/library.json",
      "./messages/{locale}/novel.json",
      "./messages/{locale}/settings.json",
      "./messages/{locale}/debug.json"
    ]
  }
}
