  "narrative": {
    "northStar": "The Adaptive Frame",
    "overview": "Shell chrome is premium by quiet precision; immersion is modal on content surfaces. Desktop 48px icon spine (collapsible, left-edge restore) + minimal titlebar; mobile bottom four realms. L0 light/dark/system; L2 dual-track themes (light face / dark face, no auto-invert). Settings denselist only for mode/theme/locale.",
    "keyCharacteristics": [
      "Semantic roles first; built-in themes rebind values without rewriting IA",
      "Restrained lantern accent on tonal neutrals",
      "Outfit for chrome; Source Serif 4 for reading; JetBrains Mono for code",
      "Tonal elevation; shadows only on controls/dialogs",
      "48px spine rail + bottom nav metrics; full-width home content",
      "Quiet density: compact controls, denselist settings, less empty shell air"
    ],
    "rules": [
      {
        "name": "The Role Stability Rule",
        "body": "Themes may re-skin hex values; they must not invent parallel meanings for canvas / ink / lantern / reader-*.",
        "section": "colors"
      },
      {
        "name": "The One Lantern Rule",
        "body": "Lantern for primary action, selection, and focus — roughly ≤10% of a screen’s color mass.",
        "section": "colors"
      },
      {
        "name": "The Honest Empty Rule",
        "body": "Prefer media-void + real copy over stock photos or fabricated shelves.",
        "section": "colors"
      },
      {
        "name": "The Serif-Only-When-Reading Rule",
        "body": "Source Serif 4 is for reader surfaces, not nav/buttons/tables.",
        "section": "typography"
      },
      {
        "name": "The Density Type Rule",
        "body": "Prefer the tighter product scale; do not inflate type to fill empty shell regions.",
        "section": "typography"
      },
      {
        "name": "The Flat-By-Default Rule",
        "body": "Resting content cards do not cast heavy drop shadows.",
        "section": "elevation"
      },
      {
        "name": "The Transparency Is Optional Rule",
        "body": "Reduced transparency must look intentional, not broken glass.",
        "section": "elevation"
      }
    ],
    "dos": [
      "Do bind UI to semantic roles so multi-theme can rebind later.",
      "Do keep one primary lantern action per region.",
      "Do preserve Adaptive Frame metrics across breakpoints.",
      "Do use Source Serif only on reader/long-form surfaces.",
      "Do honor reduced motion and reduced transparency.",
      "Do pack shell chrome tightly; spend space on media content.",
      "Do show honest empty and partial source states."
    ],
    "donts": [
      "Don't ship generic SaaS dashboard chrome and metric-card kits as the product identity.",
      "Don't build content-farm or noisy infinite-feed surfaces as the default discovery language.",
      "Don't expose scraper/pipeline guts as primary UI.",
      "Don't run multiple competing players or a second foreground activity fighting focus.",
      "Don't fill production with fake data, prototype variants, or demo fullness.",
      "Don't use side-stripe accent borders, gradient text, or decorative glassmorphism as defaults.",
      "Don't put display/serif type in buttons, tabs, or dense data.",
      "Don't invent a second color system beside the semantic roles for just this page.",
      "Don't inflate whitespace to look premium while hiding needed density."
    ]
  }
